@app.route('/api/ai_explain', methods=['POST'])
def api_ai_explain():
    try:
        data = request.get_json()
        if not GEMINI_API_KEY: return jsonify({'explanation': 'AI Key Missing'})
        prompt = f"Explain this question spatially for a blind student in {data['lang']}: {data['question_text']}"
        response = model.generate_content(prompt)
        return jsonify({'explanation': response.text})
    except Exception as e: return jsonify({'error': str(e)}), 500

@app.route('/api/extract_questions', methods=['POST'])
def api_extract_questions():
    try:
        if 'file' not in request.files: return jsonify({'error': 'No file'}), 400
        pdf_data = request.files['file'].read()
        prompt = "Extract questions from this PDF into JSON list: number, text, type, options, section_label. Output ONLY JSON."
        response = model.generate_content([prompt, {'mime_type': 'application/pdf', 'data': pdf_data}])
        # 3. استخراج الـ JSON بذكاء ومرونة
        ai_text = response.text
        questions = []
        
        # محاولة البحث عن بلوك JSON في ماركداون
        json_match = re.search(r'```json\s+(.*?)\s+```', ai_text, re.DOTALL)
        if not json_match:
            json_match = re.search(r'```\s+(.*?)\s+```', ai_text, re.DOTALL)
            
        try:
            if json_match:
                questions = json.loads(json_match.group(1))
            else:
                # إذا لم يكن هناك ماركداون، نحاول تنظيف النص واستخراجه كـ JSON خام
                clean_json = ai_text.strip()
                if clean_json.startswith('```'): clean_json = clean_json.replace('```', '')
                questions = json.loads(clean_json)
        except Exception as json_err:
            print(f"JSON Parsing Error: {json_err}\nRaw AI Text: {ai_text}")
            return jsonify({'error': 'AI generated invalid data format. Please try again.'}), 500

        if not questions:
            return jsonify({'error': 'No questions were found in the document.'}), 400

        sid = str(uuid.uuid4())
        sessions[sid] = {'questions': questions}
        
        # كشف اللغة من أول سؤال كبديل
        lang = detect_language(questions[0].get('text', ''))
        
        return jsonify({
            'success': True,
            'session_id': sid, 
            'questions': questions, 
            'language': lang,
            'total': len(questions),
            'metadata': {'instructions': 'Extracted via AI Multimodal'}
        })
    except Exception as e: return jsonify({'error': str(e)}), 500

