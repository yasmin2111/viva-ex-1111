def detect_language(text):
    """كشف لغة النص بناءً على الحروف السائدة"""
    arabic_chars = len(re.findall(r'[\u0600-\u06FF]', text))
    english_chars = len(re.findall(r'[a-zA-Z]', text))
    return 'ar' if arabic_chars > english_chars else 'en'

def extract_questions_smart(raw_text):
    """خوارزمية ريجيكس كحل بديل في حال فشل الذكاء الاصطناعي"""
    clean_text = raw_text.replace('\r', '')
    lang = detect_language(clean_text)
    
    # تبسيط الاستخراج للسرعة في الـ Fallback
    q_pattern = r'(?:^|\n)(?:\d+|[أ-ي]+)[\.\-\)]\s*(.*?)(?=\n(?:\d+|[أ-ي]+)[\.\-\)]|$)'
    matches = re.finditer(q_pattern, clean_text, re.DOTALL)
    
    questions = []
    for i, m in enumerate(matches):
        body = m.group(1).strip()
        if not body: continue
        questions.append({
            'id': i + 1, 'number': i + 1, 'text': body, 'type': 'essay',
            'options': [], 'section': 1, 'section_label': 'General Section',
            'answer': None, 'answer_time': None
        })
        
    return {
        'questions': questions,
        'metadata': {'duration': 'N/A', 'student_name': 'N/A', 'instructions': 'N/A'},
        'language': lang,
        'sections': ['General Section']
    }

